# Google Gemini (free tier — aistudio.google.com)
GEMINI_API_KEY=

# Pinecone (free tier — pinecone.io)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=graphrag-benchmark
PINECONE_ENVIRONMENT=us-east-1
PINECONE_EMBED_MODEL=llama-text-embed-v2
PINECONE_EMBEDDING_DIMENSION=1024

# TigerGraph Savanna (tgcloud.io)
TG_HOST=
TG_USERNAME=tigergraph
TG_PASSWORD=
TG_GRAPH_NAME=GraphRAG
TG_GET_TOKEN=true

# TigerGraph GraphRAG Service (Docker)
GRAPHRAG_SERVICE_URL=http://localhost:8000
# GRAPHRAG_EMBEDDING_MODEL=models/gemini-embedding-001
# GRAPHRAG_EMBEDDING_DIM=1024

# HuggingFace (free — for accuracy evaluation)
HF_TOKEN=

# App
PORT=8080
